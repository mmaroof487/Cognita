# ─────────────────────────────────────────────────────────────────────────────
# DevPulse Production Environment Variables Example
# Copy this file to .env on the production server and fill in the values.
# DO NOT COMMIT SECRETS TO SOURCE CONTROL.
# ─────────────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=production
DEBUG=0
LOG_LEVEL=WARNING

# Security
# Generate via: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Database
POSTGRES_DB=devpulse_prod
POSTGRES_USER=devpulse_user
# Generate a strong password
POSTGRES_PASSWORD=your_secure_db_password

# Redis
# Generate a strong password
REDIS_PASSWORD=your_secure_redis_password

# External APIs
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_hmac_secret

ANTHROPIC_API_KEY=your_anthropic_api_key

SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=https://app.yourdomain.com
